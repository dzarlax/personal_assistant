TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_OWNER_CHAT_ID=your_chat_id_here

# OpenRouter (openrouter.ai) — workhorse, reasoner-lite, compaction. One key, many models.
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: override the default OpenRouter model id (see config.yaml for default).
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1

# Gemini (ai.google.dev) — direct Google API for fallback + multimodal.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Tavily (app.tavily.com) — for web_search when provider: tavily in config.yaml
# Free tier: 1000 searches/month, no credit card
# TAVILY_API_KEY=your_tavily_api_key_here

# Optional: HuggingFace TEI embedding server (if using hf-tei provider in config.yaml)
# EMBED_API_KEY=user:password

# Timezone for date/time in LLM context (IANA format, e.g. Europe/Moscow, America/New_York)
TZ=Europe/Belgrade

# Optional: Claude Bridge (host service wrapping claude -p CLI)
# CLAUDE_BRIDGE_TOKEN=your_shared_secret
# CLAUDE_BRIDGE_PROJECT_DIR=/path/to/assistant_context
# CLAUDE_BRIDGE_LISTEN=0.0.0.0:9900  # must be 0.0.0.0 for Docker access (not 127.0.0.1)

# MCP servers
# MEMORY_USER=
# MEMORY_PASS=
# HEALTH_API_KEY=
